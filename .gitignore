# Go
/bin/
/out/
*.test
*.out
coverage.txt

# IDE
/.idea/
/.vscode/
*.swp

# Local env — only .env.example and .env.sops are tracked.
.env
.env.local
.env.*.local

# Local data (DB, music, slskd state). On the Pi these live under
# /srv/muzika/data, not in the repo; this keeps local-dev runs tidy.
/data/
/deploy/data/

# Frontend build artifacts. The committed placeholder index.html keeps
# //go:embed internal/web/dist/* happy until the real Vue SPA lands in
# a later phase. The CI `Stage frontend dist for embed` step overwrites
# index.html with the real build output (`cp -r frontend/dist/*`) when
# frontend/ exists; .gitkeep is hidden so `cp -r dist/*` leaves it alone.
/internal/web/dist/*
!/internal/web/dist/.gitkeep
!/internal/web/dist/index.html
/frontend/dist/
/frontend/node_modules/

# macOS
.DS_Store
