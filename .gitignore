# Go
/bin/
/out/
*.test
*.out
coverage.txt

# go.work pins a local gosk checkout for dev; CI uses the go.mod version.
/go.work
/go.work.sum

# IDE
/.idea/
/.vscode/
*.swp

# Local env — only .env.example and .env.sops are tracked.
.env
.env.local
.env.*.local

# Local data (DB, music, slskd state). On the Pi these live under
# /srv/muzika/data, not in the repo; this keeps local-dev runs tidy.
/data/
/deploy/data/

# Frontend build artifacts. CI (or a local `npm run build` + copy step)
# stages built assets into internal/web/dist/ before `go build` so
# //go:embed bakes them into the binary. Only .gitkeep is tracked; the
# real dist payload is regenerated from frontend/ sources, not committed.
/internal/web/dist/*
!/internal/web/dist/.gitkeep
/frontend/dist/
/frontend/node_modules/

# macOS
.DS_Store
