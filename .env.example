# Muzika — example configuration.
# Copy to .env, edit, then sops -e .env > deploy/.env.sops. Never commit
# plaintext .env. The pre-commit hook at .githooks/pre-commit blocks any
# .env* other than .env.example and .env.sops from being committed.
#
# On the Pi, muzika-decrypt writes every MUZIKA_* line to
# /etc/muzika/muzika.env, which muzika.service consumes as EnvironmentFile.
# No other service reads these anymore — the slskd sidecar was retired in
# v0.3.0; muzika talks Soulseek directly via github.com/ABCslime/gosk.

# --- HTTP ---
MUZIKA_HTTP_PORT=8080

# --- Storage ---
MUZIKA_DB_PATH=/data/muzika.db
MUZIKA_MUSIC_STORAGE_PATH=/data/music

# --- Auth ---
# Generate with: openssl rand -base64 48
MUZIKA_JWT_SECRET=replace-me-with-a-long-random-string
MUZIKA_JWT_EXPIRATION=24h

# --- CORS ---
# Comma-separated list of allowed origins. Empty = no CORS headers emitted.
# Never use *.
# Dev typical: http://localhost:3000
MUZIKA_CORS_ORIGINS=

# --- Soulseek network account ---
# Register free at https://www.slsknet.org/ — this is the real Soulseek P2P
# credential muzika uses to authenticate to the public Soulseek server.
MUZIKA_SOULSEEK_USERNAME=
MUZIKA_SOULSEEK_PASSWORD=

# Server address defaults to the public Soulseek server; leave as-is unless
# you're running your own. Listen port is for incoming peer connections.
MUZIKA_SOULSEEK_SERVER_ADDRESS=server.slsknet.org
MUZIKA_SOULSEEK_SERVER_PORT=2242
MUZIKA_SOULSEEK_LISTEN_PORT=2234

# SQLite file for gosk's in-flight-download state; survives restarts.
MUZIKA_GOSK_STATE_PATH=/data/gosk-state.db

# --- Queue tuning ---
MUZIKA_MIN_QUEUE_SIZE=10
MUZIKA_BANDCAMP_WORKERS=2
MUZIKA_DOWNLOAD_WORKERS=2
MUZIKA_BANDCAMP_DEFAULT_TAGS=electronic,house
MUZIKA_BUS_BUFFER_SIZE=64

# --- Discogs seeder (v0.4 PR 2) ---
# The second discovery source. Default off so upgrades from v0.3.x don't
# require ops action. Flip MUZIKA_DISCOGS_ENABLED=true after generating a
# Personal Access Token at https://www.discogs.com/settings/developers.
# Cached 30 days in SQLite; 60 req/min rate limited client-side.
MUZIKA_DISCOGS_ENABLED=false
MUZIKA_DISCOGS_TOKEN=
MUZIKA_DISCOGS_WORKERS=1
# DISCOGS_DEFAULT_GENRES uses Discogs' closed vocabulary (Electronic, Rock,
# Jazz, Hip Hop, Funk / Soul, ...). Separate from BANDCAMP_DEFAULT_TAGS
# (which is Bandcamp's free-form tag vocabulary). v0.6 adds cross-source
# mapping; until then, these two knobs are independent.
MUZIKA_DISCOGS_DEFAULT_GENRES=Electronic,Rock
# Probability the refiller routes a DiscoveryIntent to Discogs vs Bandcamp.
# 0.3 default keeps Bandcamp as the reliability floor; set 0.0 to mute
# Discogs without unsetting DISCOGS_ENABLED.
MUZIKA_DISCOGS_WEIGHT=0.3

# --- Quality gate (v0.4 PR 2) ---
# Applied to every Soulseek SearchResult. Strict thresholds first; if
# every rung rejects strict, a single relax pass halves the floors and
# doubles the ceilings before giving up. See ROADMAP §v0.4 item 3.
MUZIKA_DOWNLOAD_MIN_BITRATE_KBPS=192
MUZIKA_DOWNLOAD_MIN_FILE_BYTES=2000000
MUZIKA_DOWNLOAD_MAX_FILE_BYTES=200000000
MUZIKA_DOWNLOAD_PEER_MAX_QUEUE=50

# --- Ladder search strategy (v0.4 PR 2) ---
# Catalog-number ladder: [catno, artist+title, title]. First rung with
# LADDER_ENOUGH_RESULTS post-gate passes wins and the rest are skipped.
# RUNG_WINDOW bounds rungs after the first (which uses the default
# search window internal to the download package).
MUZIKA_DOWNLOAD_LADDER_ENABLED=true
MUZIKA_DOWNLOAD_LADDER_ENOUGH_RESULTS=3
MUZIKA_DOWNLOAD_LADDER_RUNG_WINDOW=5s

# --- Observability ---
MUZIKA_LOG_LEVEL=info
