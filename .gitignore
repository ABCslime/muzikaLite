/data/
/deploy/data/

# Frontend build artifacts (populated by the Docker-less CI build or by
# `npm run build` locally; embedded via //go:embed).
/internal/web/dist/*
!/internal/web/dist/.keep
/frontend/dist/
/frontend/node_modules/

# macOS
.DS_Store
