# Muzika — example configuration.
# Copy to .env, edit, then sops -e .env > deploy/.env.sops. Never commit
# plaintext .env. The pre-commit hook at .githooks/pre-commit blocks any
# .env* other than .env.example and .env.sops from being committed.
#
# On the Pi, muzika-update splits the decrypted file by variable prefix:
#   MUZIKA_*                 -> /etc/muzika/muzika.env  (consumed by muzika.service)
#   SLSKD_*, SOULSEEK_*      -> /etc/muzika/slskd.env   (consumed by slskd.service)
#
# The same value may need to appear under both a MUZIKA_SLSKD_* name
# (muzika's client credentials) and an SLSKD_* name (slskd's own admin
# credentials) — they must match for muzika to authenticate to slskd.

# --- HTTP ---
MUZIKA_HTTP_PORT=8080

# --- Storage ---
MUZIKA_DB_PATH=/data/muzika.db
MUZIKA_MUSIC_STORAGE_PATH=/data/music

# --- Auth ---
# Generate with: openssl rand -base64 48
MUZIKA_JWT_SECRET=replace-me-with-a-long-random-string
MUZIKA_JWT_EXPIRATION=24h

# --- CORS ---
# Comma-separated list of allowed origins. Empty = no CORS headers emitted.
# Never use *.
# Dev typical: http://localhost:3000
MUZIKA_CORS_ORIGINS=

# --- Soulseek backend ---
# "slskd" (default, uses the slskd systemd sidecar) or "native" (gosk,
# pure-Go implementation in github.com/ABCslime/gosk).
MUZIKA_SOULSEEK_BACKEND=slskd

# --- slskd backend config (required when SOULSEEK_BACKEND=slskd) ---
# Admin credentials for the slskd daemon's HTTP API.
MUZIKA_SLSKD_URL=http://slskd:5030
MUZIKA_SLSKD_USERNAME=muzika
MUZIKA_SLSKD_PASSWORD=replace-me

# --- slskd sidecar service env (split into slskd.env by muzika-decrypt) ---
# The slskd.service EnvironmentFile reads these. Admin creds MUST match
# the MUZIKA_SLSKD_* values above.
SLSKD_USERNAME=muzika
SLSKD_PASSWORD=replace-me

# --- Soulseek network account (real Soulseek P2P credentials) ---
# Register at https://www.slsknet.org/ — same account used by both
# backends. slskd needs them as SLSKD_SLSK_*; gosk reads MUZIKA_SOULSEEK_*.
SLSKD_SLSK_USERNAME=
SLSKD_SLSK_PASSWORD=
MUZIKA_SOULSEEK_USERNAME=
MUZIKA_SOULSEEK_PASSWORD=

# --- gosk-only (required when SOULSEEK_BACKEND=native) ---
# Server address defaults to the public Soulseek server; leave as-is unless
# you're running your own. Listen port is for incoming peer connections.
MUZIKA_SOULSEEK_SERVER_ADDRESS=server.slsknet.org
MUZIKA_SOULSEEK_SERVER_PORT=2242
MUZIKA_SOULSEEK_LISTEN_PORT=2234
# SQLite file for gosk's in-flight-download state; survives restarts.
MUZIKA_GOSK_STATE_PATH=/data/gosk-state.db

# --- Queue tuning ---
MUZIKA_MIN_QUEUE_SIZE=10
MUZIKA_BANDCAMP_WORKERS=2
MUZIKA_SLSKD_WORKERS=2
MUZIKA_BANDCAMP_DEFAULT_TAGS=electronic,house
MUZIKA_BUS_BUFFER_SIZE=64

# --- Observability ---
MUZIKA_LOG_LEVEL=info
